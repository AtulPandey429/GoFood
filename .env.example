URL=mongodb://localhost:27017/gofood
ACCESS_TOKEN_SECRET=your_jwt_secret_here
PORT=3000
NODE_ENV=development
SANDBOX_MODE=true
# mainnet | testnet — MUST match Gem wallet network
CRYPTO_NETWORK=testnet
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=gofood_429_bot
# Public hostname for BotFather /setdomain (NOT localhost). Example: abc123.ngrok-free.app
TELEGRAM_LOGIN_DOMAIN=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
CLIENT_URL=http://localhost:3001
# mainnet | testnet — must match Gem/Freighter network and merchant addresses
CRYPTO_NETWORK=mainnet
# Optional overrides (defaults picked from CRYPTO_NETWORK)
# XRPL_HTTP_URL=https://xrplcluster.com/
# STELLAR_HORIZON_URL=https://horizon.stellar.org
MERCHANT_XRP_ADDRESS=
MERCHANT_XLM_ADDRESS=
ADMIN_EMAIL=
COINGECKO_API_KEY=
CORS_ORIGIN=http://localhost:3001
# Menu AI — add any free keys below (no credit card for Gemini/Groq/OpenRouter/Cerebras)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GROQ_API_KEY=          # https://console.groq.com/keys
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=    # https://openrouter.ai/keys
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# CEREBRAS_API_KEY=      # https://cloud.cerebras.ai/
# CEREBRAS_MODEL=llama3.1-8b
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
MENU_AI_PROVIDER_ORDER=gemini,groq,openrouter,cerebras,openai
